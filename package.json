{
  "name": "mcp-server-japan-atlas",
  "version": "1.0.0",
  "description": "An MCP server that provides structured Japanese address normalization and geospatial context via official Japanese public APIs.",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-japan-atlas": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "japan",
    "japanese-address",
    "geocoding",
    "gsi",
    "elevation",
    "claude",
    "anthropic"
  ],
  "author": "b84330808",
  "repository": {
    "type": "git",
    "url": "https://github.com/b84330808/mcp-server-japan-atlas.git"
  },
  "homepage": "https://github.com/b84330808/mcp-server-japan-atlas#readme",
  "bugs": {
    "url": "https://github.com/b84330808/mcp-server-japan-atlas/issues"
  },
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
